{
	"name": "@w-lfpup/superaction",
	"type": "module",
	"main": "dist/mod.js",
	"description": "A hypertext extension to dispatch meaningful actions from UI events",
	"license": "BSD-3-Clause",
	"version": "0.4.3",
	"scripts": {
		"prepare": "npm run build",
		"build": "npm run build:core && npm run build:examples && npm run build:tests",
		"build:core": "npx tsc --project src/",
		"build:examples": "npx tsc --project examples/",
		"build:tests": "npx tsc --project tests/",
		"test": "npm run test:browsers",
		"test:browsers": "npx jackrabbit_webdriver jr.json tests/dist/mod.js",
		"format": "npx prettier ./ --write"
	},
	"devDependencies": {
		"@w-lfpup/jackrabbit": "file:../jackrabbit-js",
		"prettier": "^3.8.3",
		"typescript": "^6.0.2"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/w-lfpup/superaction-js.git"
	}
}
